---
import ContentCard from "../components/ContentCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteContent } from "../data/site";

const { metadata, hero, stats, workflow, capabilities, systemHighlights, systemSurfaces, links, runtimePointers, closing } =
  siteContent;
---

<BaseLayout title={metadata.title} description={metadata.description}>
  <main class="site-shell">
    <section class="hero-panel">
      <div class="hero-copy">
        <p class="eyebrow">{hero.eyebrow}</p>
        <h1>{hero.title}</h1>
        <p class="hero-summary">{hero.summary}</p>
        <p class="hero-supporting">{hero.supporting}</p>
        <div class="cta-row">
          <a class="button" href={hero.primaryCta.href} target="_blank" rel="noreferrer">
            {hero.primaryCta.label}
          </a>
          <a class="button button-secondary" href={hero.secondaryCta.href}>
            {hero.secondaryCta.label}
          </a>
        </div>
      </div>

      <div class="hero-aside">
        <div class="stats-grid">
          {
            stats.map((stat) => (
              <article class="stat-card">
                <strong>{stat.value}</strong>
                <span>{stat.label}</span>
                <p>{stat.description}</p>
              </article>
            ))
          }
        </div>

        <article class="blueprint-card">
          <p class="card-kicker">Modelo operativo</p>
          <h2>Mission → Spec → Graph → Run → Verify → Release</h2>
          <p>
            La misión organiza el contexto, el spec fija el contrato, el graph ordena ownership y el
            runtime ejecuta bajo policies explícitas.
          </p>
        </article>
      </div>
    </section>

    <section id="como-funciona" class="content-section">
      <SectionHeader
        eyebrow="Cómo funciona"
        title="La misión estructura el trabajo antes de que empiece la ejecución."
        intro="Lobo Builder define un flujo estable para pasar de un brief a una misión operable, con contratos persistidos, ownership claro y un runtime que puede inspeccionarse en cada etapa."
      />

      <div class="cards-grid cards-grid-wide">
        {
          workflow.map((item) => (
            <ContentCard title={item.title} description={item.description} footer={item.footer} />
          ))
        }
      </div>
    </section>

    <section id="puede-hacer" class="content-section">
      <SectionHeader
        eyebrow="Qué Incluye"
        title="La plataforma combina modelo de misión, runtime operativo, gobierno y observabilidad."
        intro="La página no resume una etapa del proyecto: presenta las piezas que definen a Lobo Builder como producto y que explican cómo se comporta cuando una misión entra al sistema."
      />

      <div class="cards-grid">
        {
          capabilities.map((item) => (
            <ContentCard title={item.title} description={item.description} items={item.items} />
          ))
        }
      </div>

      <div class="band-grid">
        <article class="band-card">
          <p class="card-kicker">Operación</p>
          <h3>Cómo se ejecuta una misión</h3>
          <p>
            Una misión se corre desde el hub con acciones explícitas de control. El runner prepara el
            entorno de trabajo, conserva el estado operativo y deja trazabilidad suficiente para
            entender qué pasó durante la ejecución.
          </p>
        </article>

        <article class="band-card">
          <p class="card-kicker">Arquitectura</p>
          <h3>{systemHighlights.title}</h3>
          <p>{systemHighlights.description}</p>
          <ul class="card-list">
            {systemHighlights.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </section>

    <section id="arquitectura" class="content-section">
      <SectionHeader
        eyebrow="Superficies"
        title="El sistema se entiende mejor cuando se mira por capas."
        intro="Planner, runner, dashboard, APIs e integraciones cumplen funciones distintas dentro de un mismo control plane. Esa separación hace que el producto sea gobernable y legible."
      />

      <div class="cards-grid">
        {
          systemSurfaces.map((item) => (
            <ContentCard kicker="Componente" title={item.title} description={item.description} footer={item.footer} />
          ))
        }
      </div>
    </section>

    <section id="cta-final" class="content-section closing-section">
      <SectionHeader eyebrow={closing.eyebrow} title={closing.title} intro={closing.description} />

      <div class="link-grid">
        {
          links.map((link) => (
            <article class="link-card">
              <h3>{link.title}</h3>
              <p>{link.description}</p>
              <a href={link.href} target="_blank" rel="noreferrer">
                {link.label}
              </a>
            </article>
          ))
        }
      </div>

      <div class="runtime-grid">
        {
          runtimePointers.map((pointer) => (
            <article class="runtime-card">
              <h3>{pointer.title}</h3>
              <p>{pointer.description}</p>
              <code>{pointer.value}</code>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
